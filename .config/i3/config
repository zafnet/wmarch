# INICIE I3BAR PARA MOSTRAR UNA BARRA DE ESPACIO DE TRABAJO HAY QUE INSTALAR I3BLOCKS SI DICE ERROR 127 #

bar {
		font pango: Hack Nerd Fonts 10
		status_command i3blocks -c ~/.config/i3/i3blocks.conf
	    	position top
#	    	i3bar_command i3bar --transparency
# PODR√ćA SER QUE NO TENGA CONFIGURADA LA PANTALLA PRINCIPAL: set one (xrandr --output <output> --primary)
# REFERENCIA: https://i3wm.org/docs/userguide.html#_tray_output ESTE ES PARA BANDEJA DE ENTRADA
#		    tray_output primary
#		    tray_padding 0

# CUANDO STRIP_WORKSPACE_NUMBERS SE ESTABLECE EN S√ć,
# CUALQUIER ESPACIO DE TRABAJO QUE TENGA EL NOMBRE DEL FORMULARIO
# ‚Äú[n][:][NAME]‚ÄĚ MOSTRAR√Ā S√ďLO EL NOMBRE
strip_workspace_numbers yes
##strip_workspace_name no

		    colors {
		    separator          $purple
		    background         $darkgrey
		    statusline         $white
#                          		 		border        bg		        txt	        indicator
		focused_workspace	            $mediumgrey	   $grey	         $darkgrey    	$purple
		active_workspace	      	   $lightblue     $mediumgrey	   $darkgrey   	$purple
		inactive_workspace	   		 $darkgrey      $darkgrey	   $grey	         $purple
		urgent_workspace		    	    $urgentred     $urgentred	    $white		   $purple
	}
}


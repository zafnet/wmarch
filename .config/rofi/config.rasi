configuration {
   modi: "window,run,ssh,filebrowser,keys,drun,windowcd,combi";
	font: "IBM 3270 Bold 13";
   width: 100;
   combi-modi: "drun,run";
   padding: 3;
   line-margin: 2;
   line-padding: 1;
   background-color: #0b0000;
   border-color: #ffd966;
   show-icons: true;
   fake-transparency: true;
	sorting-method: "normal";
	case-sensitive: false;
	cycle: true;
	sidebar-mode: true;
   display-combi:"Combinado";
   display-window: "Ventanas";
   display-run: "Exes";
	display-drun: "Aplicaciones";
	display-keys:"Atajos";
	display-filebrowser:"Archivos";

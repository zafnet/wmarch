* {
 
    border-color: #ffd966;
    anchor: south;
    location: south;
    lines: 10;
    columns: 4;
    sort: true;
    hide-scrollbar: true;
    fullscreen: false;
    
}


filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }

window {
    transparency: true;
    border-radius: 10px;
    background-color: #0b0000;
    border: 1;
    padding: 2%;
    x-offset: 0;
    y-offset: 0%;
    width:      100%;
    padding:    0%;
    separator-style: "none";
}



prompt normal.normal {
    background-color: #000000;
    color: #ff00a9;
    padding: 0px;
}

textbox-prompt-colon {
	/*padding: 						8px 15px 10px 15px;*/
	/*font:							"IBM 3270 Bold 13";*/
	/*background-color: 				@al;*/
	/*expand: false;*/
    str: ">";
    text-color: 					#ff2100;	
    
}

inputbar {
    spacing: 0;
    background-color: #0b0000;
    padding: 1px 1px 1px 1px;
    spacing: 10;
    border: 0px 0px 0px 0px;
    border-radius: 0px;
    padding: 5px 10px 5px 35px;
}

entry normal.normal {
    background-color: #00000000;
    color: #00ff36;
    padding: 0px;
}


listview {
    // Looks.
    border-radius: 0px;
    border: 0px 0px 0px 0px;
    padding: 0px 0px 0px 0px;
    margin: 0px 0px 0px 0px;
    background-color: #0b0000;
    // Enable scrollbar
    scrollbar: false;
    scrollbar-width: 15px;
    fixed-height: true;
    reverse: false;
    color: #00ff1e;
    spacing: 0.3em;
}

element {
    border: 0;
    padding: 0px;
    highlight: bold ;
    /*background-color: ;*/
    /*text-color: #00FF36;*/
}

element normal.normal {
    text-color: #ff009b;
    background-color: #0b0000;
}

element selected.normal {
    text-color: #ff009b;
    background-color:#ffdb8e;
}

element alternate.normal {
    text-color: #ff009b;
   background-color: #0b0000;
}

